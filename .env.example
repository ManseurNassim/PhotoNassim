# Google Cloud Vision API
# Télécharge la clé JSON depuis https://console.cloud.google.com/
# Mets le chemin absolu ou relatif vers le fichier de clé
GOOGLE_APPLICATION_CREDENTIALS=./google-vision-key.json

# Cloudinary
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ta_api_key
CLOUDINARY_API_SECRET=ton_secret

# GitHub Actions (optionnel, utilisé dans CI/CD)
# GITHUB_TOKEN=utilisé automatiquement
